---
// src/pages/en/tools/timestamp-converter.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import TimestampConverter from '../../../tools/timestamp-converter/TimestampConverter'
import { getTranslation } from '../../../i18n'

const t = getTranslation('en')
const toolT = t.tools['timestamp-converter']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription="Convert Unix timestamps to dates and back, auto-detecting seconds or ms"
  lang="en"
  category="converter"
>
  <TimestampConverter client:load lang="en" />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
