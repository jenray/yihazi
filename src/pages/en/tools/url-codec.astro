---
// src/pages/en/tools/url-codec.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import UrlCodec from '../../../tools/url-codec/UrlCodec'
import { getTranslation } from '../../../i18n'

const t = getTranslation('en')
const toolT = t.tools['url-codec']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription="Encode and decode URLs, handling special characters and Unicode"
  lang="en"
  category="developer"
>
  <UrlCodec client:load lang="en" />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
