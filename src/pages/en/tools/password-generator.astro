---
// src/pages/en/tools/password-generator.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import PasswordGenerator from '../../../tools/password-generator/PasswordGenerator'
import { getTranslation } from '../../../i18n'

const t = getTranslation('en')
const toolT = t.tools['password-generator']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription="Customize rules and generate secure random passwords"
  lang="en"
  category="generator"
>
  <PasswordGenerator client:load lang="en" />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
