---
// src/pages/en/tools/diff-checker.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import DiffChecker from '../../../tools/diff-checker/DiffChecker'
import { getTranslation } from '../../../i18n'

const t = getTranslation('en')
const toolT = t.tools['diff-checker']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription={toolT.shortDescription}
  lang="en"
  category="text"
>
  <DiffChecker client:load lang="en" />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
