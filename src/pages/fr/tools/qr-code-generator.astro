---
// src/pages/fr/tools/qr-code-generator.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import QrCodeGenerator from '../../../tools/qr-code-generator/QrCodeGenerator'
import { getTranslation } from '../../../i18n'

const lang = 'fr'
const t = getTranslation(lang)
const toolT = t.tools['qr-code-generator']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription={toolT.shortDescription}
  lang={lang as any}
  category="generator"
>
  <QrCodeGenerator client:load lang={lang as any} />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
