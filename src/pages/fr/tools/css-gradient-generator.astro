---
// src/pages/fr/tools/css-gradient-generator.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import CssGradientGenerator from '../../../tools/css-gradient-generator/CssGradientGenerator'
import { getTranslation } from '../../../i18n'

const lang = 'fr'
const t = getTranslation(lang)
const toolT = t.tools['css-gradient-generator']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription={toolT.shortDescription}
  lang={lang as any}
  category="generator"
>
  <CssGradientGenerator client:load lang={lang as any} />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
