---
// src/pages/fr/tools/jwt-decoder.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import JwtDecoder from '../../../tools/jwt-decoder/JwtDecoder'
import { getTranslation } from '../../../i18n'

const lang = 'fr'
const t = getTranslation(lang)
const toolT = t.tools['jwt-decoder']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription={toolT.shortDescription}
  lang={lang as any}
  category="developer"
>
  <JwtDecoder client:load lang={lang as any} />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
