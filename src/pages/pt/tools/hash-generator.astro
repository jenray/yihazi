---
// src/pages/pt/tools/hash-generator.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import HashGenerator from '../../../tools/hash-generator/HashGenerator'
import { getTranslation } from '../../../i18n'

const lang = 'pt'
const t = getTranslation(lang)
const toolT = t.tools['hash-generator']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription={toolT.shortDescription}
  lang={lang as any}
  category="developer"
>
  <HashGenerator client:load lang={lang as any} />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
