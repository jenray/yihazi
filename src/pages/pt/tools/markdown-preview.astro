---
// src/pages/pt/tools/markdown-preview.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import MarkdownPreview from '../../../tools/markdown-preview/MarkdownPreview'
import { getTranslation } from '../../../i18n'

const lang = 'pt'
const t = getTranslation(lang)
const toolT = t.tools['markdown-preview']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription={toolT.shortDescription}
  lang={lang as any}
  category="developer"
>
  <MarkdownPreview client:load lang={lang as any} />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
