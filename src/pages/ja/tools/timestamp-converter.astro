---
// src/pages/ja/tools/timestamp-converter.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import TimestampConverter from '../../../tools/timestamp-converter/TimestampConverter'
import { getTranslation } from '../../../i18n'

const lang = 'ja'
const t = getTranslation(lang)
const toolT = t.tools['timestamp-converter']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription={toolT.shortDescription}
  lang={lang as any}
  category="converter"
>
  <TimestampConverter client:load lang={lang as any} />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
