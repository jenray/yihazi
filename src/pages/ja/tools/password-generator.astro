---
// src/pages/ja/tools/password-generator.astro
import ToolLayout from '../../../layouts/ToolLayout.astro'
import PasswordGenerator from '../../../tools/password-generator/PasswordGenerator'
import { getTranslation } from '../../../i18n'

const lang = 'ja'
const t = getTranslation(lang)
const toolT = t.tools['password-generator']
---

<ToolLayout
  title={toolT.pageTitle}
  pageTitle={toolT.title}
  description={toolT.description}
  pageDescription={toolT.shortDescription}
  lang={lang as any}
  category="developer"
>
  <PasswordGenerator client:load lang={lang as any} />
  <Fragment slot="seo-content" set:html={toolT.seoContent} />
</ToolLayout>
