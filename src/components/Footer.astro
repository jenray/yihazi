---
// src/components/Footer.astro
interface Props {
  lang?: 'zh' | 'en' | 'ja' | 'es' | 'pt' | 'fr'
}

const { lang = 'zh' } = Astro.props
const year = new Date().getFullYear()

const translations = {
  zh: { msg: '一哈子，搞定！', about: '关于', privacy: '隐私政策', contact: '联系' },
  en: { msg: 'Get it done in a snap!', about: 'About', privacy: 'Privacy', contact: 'Contact' },
  ja: { msg: '一瞬で完了！', about: '概要', privacy: 'プライバシー', contact: '連絡先' },
  es: { msg: '¡Hazlo en un instante!', about: 'Acerca de', privacy: 'Privacidad', contact: 'Contacto' },
  pt: { msg: 'Faça em um instante!', about: 'Sobre', privacy: 'Privacidade', contact: 'Contato' },
  fr: { msg: 'Fait en un instant !', about: 'À propos', privacy: 'Confidentialité', contact: 'Contact' },
}
const t = translations[lang as keyof typeof translations] || translations.zh

const route = (path: string) => lang === 'zh' ? `/${path}` : `/${lang}/${path}`
---

<footer class="border-t border-gray-100 bg-gray-50 mt-auto">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500">
      <p>© {year} yihazi.com — {t.msg}</p>
      <div class="flex gap-4 flex-wrap justify-center">
        <a href={route('about')} class="hover:text-gray-900 transition-colors">
          {t.about}
        </a>
        <a href={route('privacy')} class="hover:text-gray-900 transition-colors">
          {t.privacy}
        </a>
        <a href="mailto:hi@yihazi.com" class="hover:text-gray-900 transition-colors">
          {t.contact}
        </a>
      </div>
    </div>
  </div>
</footer>
